#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

usage() {
  echo "Usage: $0 [--dry-run] <module-name> <flat|standard> [allowed-dependencies]" >&2
  exit 1
}

class_name() {
  local raw="$1"
  printf '%s%s' "$(printf '%s' "${raw:0:1}" | tr '[:lower:]' '[:upper:]')" "${raw:1}"
}

module_annotation() {
  local deps="$1"
  if [[ -z "$deps" || "$deps" == "none" ]]; then
    printf '%s\n' "@org.springframework.modulith.ApplicationModule"
    return
  fi

  IFS=',' read -r -a dep_array <<< "$deps"
  for i in "${!dep_array[@]}"; do
    dep_array[$i]="$(printf '%s' "${dep_array[$i]}" | xargs)"
  done

  if [[ ${#dep_array[@]} -eq 1 ]]; then
    printf '%s\n' "@org.springframework.modulith.ApplicationModule(allowedDependencies = \"${dep_array[0]}\")"
    return
  fi

  local quoted=()
  for dep in "${dep_array[@]}"; do
    quoted+=("\"$dep\"")
  done

  printf '%s\n' "@org.springframework.modulith.ApplicationModule(allowedDependencies = {${quoted[*]// /, }})"
}

dry_run=false
if [[ ${1:-} == "--dry-run" ]]; then
  dry_run=true
  shift
fi

[[ $# -ge 2 ]] || usage

module_name="$1"
pattern="$2"
allowed_deps="${3:-none}"

if [[ ! "$module_name" =~ ^[a-z][a-z0-9]*$ ]]; then
  echo "Module name must match ^[a-z][a-z0-9]*$" >&2
  exit 1
fi

if [[ "$pattern" != "flat" && "$pattern" != "standard" ]]; then
  usage
fi

# Derive base package from the *Application.java file location
app_file="$(find "$repo_root/src/main/java" -maxdepth 5 -name '*Application.java' -not -path '*/test/*' | head -1)"
if [[ -z "$app_file" ]]; then
  echo "Cannot find *Application.java under src/main/java — is this a valid project?" >&2
  exit 1
fi
app_dir="$(dirname "$app_file")"
base_package_path="${app_dir#"$repo_root/src/main/java/"}"
base_package="${base_package_path//\//.}"

module_class="$(class_name "$module_name")"
module_dir="$repo_root/src/main/java/$base_package_path/$module_name"
module_contract="$repo_root/.claude/rules/modules/$module_name.md"
module_agents="$module_dir/AGENTS.md"
module_paths="src/main/java/$base_package_path/$module_name/**"

if [[ -e "$module_dir" || -e "$module_contract" ]]; then
  echo "Module already exists: $module_name" >&2
  exit 1
fi

if [[ "$dry_run" == true ]]; then
  echo "Would create src/main/java/$base_package_path/$module_name/"
  echo "Would create .claude/rules/modules/$module_name.md"
  exit 0
fi

mkdir -p "$module_dir"
mkdir -p "$repo_root/.claude/rules/modules"
if [[ "$pattern" == "standard" ]]; then
  mkdir -p "$module_dir/internal" "$module_dir/persistence" "$module_dir/rest"
fi

cat >"$module_dir/package-info.java" <<EOF
@org.jspecify.annotations.NullMarked
$(module_annotation "$allowed_deps")
package $base_package.$module_name;
EOF

if [[ "$pattern" == "standard" ]]; then
  for subpkg in internal persistence rest; do
    cat >"$module_dir/$subpkg/package-info.java" <<EOF
@org.jspecify.annotations.NullMarked
package $base_package.$module_name.$subpkg;
EOF
  done
fi

cat >"$module_dir/${module_class}.java" <<EOF
package $base_package.$module_name;

public record ${module_class}(String id) {}
EOF

cat >"$module_dir/${module_class}API.java" <<EOF
package $base_package.$module_name;

import java.util.List;
import java.util.Optional;

public interface ${module_class}API {
  List<${module_class}> findAll();

  Optional<${module_class}> findById(String id);
}
EOF

cat >"$module_agents" <<EOF
# ${module_class} Module Rules

This module was scaffolded by \`scripts/harness/new-module\`. The enforced source of truth for ownership, API, and validation details is [${module_name}.md](../../../../../../../.claude/rules/modules/${module_name}.md).

## Purpose
TODO: describe what the module owns.

## Local Workflow Rules
- Module type: $pattern
- Allowed dependencies: $allowed_deps
- Keep the module root package as the published API only.

## Change Rules
- Update [${module_name}.md](../../../../../../../.claude/rules/modules/${module_name}.md) until all TODO sections there are replaced with real ownership and validation details.
- Keep \`package-info.java\` aligned with the real allowed dependencies.
- Use \`scripts/harness/full-check\` before considering the scaffolded module complete.
EOF

cat >"$module_contract" <<EOF
---
paths:
  - "$module_paths"
---

# ${module_class} module contract

## Purpose
TODO: describe what the module owns.

## Complexity
$pattern

## Public API (root package)

| Type | Role |
|------|------|
| \`${module_class}API\` | Module API interface |
| \`${module_class}\` | Domain record |

Event records also live in the root package — they are part of the public API. Consumer modules import event classes from the publisher.
EOF

if [[ "$pattern" == "standard" ]]; then
cat >>"$module_contract" <<EOF

## Hidden packages (implementation details)

| Package | Contains |
|---------|----------|
| \`internal/\` | Use cases, port interfaces, configuration |
| \`persistence/\` | Entity records, repository adapters, Spring Data interfaces |
| \`rest/\` | Controllers, request/response DTOs, exception handlers |
EOF
fi

cat >>"$module_contract" <<EOF

## Allowed dependencies
$allowed_deps

**Important:** Mirror this list in \`package-info.java\` using \`@ApplicationModule(allowedDependencies = ...)\`. Without that, Spring Modulith does not enforce the boundary — this markdown is documentation only.

## Cross-module communication
- **Direct API calls** for reads/queries (synchronous, the caller needs the result).
- **Events** for state-changing notifications (fire-and-forget, "this happened, react if you care").
- Never use events as a request/response mechanism — if you need an answer, call the API.

## Owned resources
- **Database table(s):** TODO
- **REST endpoints:** TODO
- **Events published:** TODO
- **Events consumed:** TODO

## Consumer surface

> Omit or mark N/A for flat/internal-only modules with no external consumers.

| Endpoint | Method | Request body | Success response | Error responses |
|----------|--------|-------------|-----------------|-----------------|
| TODO | TODO | TODO | TODO | TODO |

### Behavioral notes
TODO: intent, idempotency, retry-safety, UX expectations.

## Validation commands
\`\`\`bash
# Fast: unit tests only (no Docker needed)
./mvnw -q test -Dtest="TODO"

# Slice tests (Docker required)
./mvnw -q test -Dtest="TODO"

# Module test (Docker required)
./mvnw -q test -Dtest="${module_class}ModuleTest"

# Integration test (Docker required)
./mvnw -q test -Dtest="${module_class}IntegrationTest"

# Full verification
./mvnw -q verify
\`\`\`

## Rules for changes in this module
- Every \`package-info.java\` must have \`@org.jspecify.annotations.NullMarked\`. New subpackages need their own \`package-info.java\`.
- New public types in root package must be added to the "Public API" table above
- New internal classes must follow existing patterns per \`.claude/rules/modulith.md\`
- No other module may directly access this module's owned tables
- Update this contract when adding public API types, endpoints, tables, or dependencies
- Keep \`package-info.java\` in sync with the "Allowed dependencies" section above
- Update the consumer surface section when adding, changing, or removing endpoints or response shapes
EOF

echo "Created module scaffold:"
echo "  src/main/java/$base_package_path/$module_name/"
echo "  .claude/rules/modules/$module_name.md"
