#!/usr/bin/env bash
set -euo pipefail

# DoD Stop hook check — called by .claude/settings.json Stop hook.
#
# Behavior:
#   CRITICAL tier, no verified_at  → block (hard enforcement)
#   Other tiers, no verified_at    → surface warning (nudge, not wall)
#   No state file + prod changes   → surface warning
#   No state file + no prod changes → silent (Q&A, discussion, critique)
#   verified_at present             → silent

command -v jq >/dev/null 2>&1 || exit 0

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
state_file="$repo_root/.claude/dod-current.json"

block() {
  jq -n --arg msg "$1" '{decision: "block", reason: $msg}'
}

surface() {
  jq -n --arg msg "$1" '{reason: $msg}'
}

has_prod_changes() {
  cd "$repo_root"
  # Check both staged and unstaged changes to src/main/
  git diff --name-only HEAD -- 'src/main/' 2>/dev/null | grep -q . && return 0
  git diff --name-only --cached -- 'src/main/' 2>/dev/null | grep -q . && return 0
  # Also check untracked files in src/main/
  git ls-files --others --exclude-standard -- 'src/main/' 2>/dev/null | grep -q . && return 0
  return 1
}

# No state file
if [[ ! -f "$state_file" ]]; then
  if has_prod_changes; then
    surface "Production code was changed but no DoD exit condition was stated. Consider invoking the /dod skill."
  fi
  # No state file + no prod changes = silent (Q&A, discussion)
  exit 0
fi

# Malformed JSON
if ! jq empty "$state_file" 2>/dev/null; then
  surface "DoD state file is malformed JSON. Regenerate it by invoking the /dod skill."
  exit 0
fi

# Check for verified_at timestamp
verified_at=$(jq -r '.verified_at // empty' "$state_file" 2>/dev/null)
if [[ -n "$verified_at" ]]; then
  # All good
  exit 0
fi

# No verified_at — behavior depends on tier
tier=$(jq -r '.risk_tier // "unknown"' "$state_file" 2>/dev/null)
task=$(jq -r '.task // "unknown"' "$state_file" 2>/dev/null)
exit_cond=$(jq -r '.exit_condition // "unknown"' "$state_file" 2>/dev/null)

if [[ "$tier" == "CRITICAL" ]]; then
  block "CRITICAL task not yet verified. Task: $task | Run: $exit_cond -- then run scripts/harness/full-check to stamp verified_at. CRITICAL tasks require verified_at before finishing."
else
  surface "DoD exit condition not yet verified. Task: $task | Tier: $tier | Run: $exit_cond -- consider running verification before finishing."
fi

exit 0
