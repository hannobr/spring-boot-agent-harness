#!/usr/bin/env bash
# Maven wrapper that routes through run-cmd for minimal output.
# Usage: scripts/harness/mvn [MAVEN_ARGS...]
# Example: scripts/harness/mvn test -Dtest=FooTest

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# Derive label from all non-flag arguments (Maven goals/phases)
label=""
for arg in "$@"; do
  if [[ "$arg" != -* ]]; then
    label="${label:+$label }$arg"
  fi
done
[[ -z "$label" ]] && label="mvn"

cd "$repo_root"
exec "$repo_root/scripts/harness/run-cmd" --label "$label" -- ./mvnw "$@"
