#!/usr/bin/env bash
# Generic command runner — minimal output, full log on disk.
#
# Usage: run-cmd [--error-pattern PATTERN] [--label LABEL] -- COMMAND [ARGS...]
#
# On success: prints "<label> succeeded (Xs)"
# On failure: prints error lines (capped at 20) + log file path, exits with command's exit code.
# Full output always written to target/runner.log (overwritten each invocation).
# During execution, output goes to a temp file to survive commands that delete target/ (e.g. mvn clean).
# The temp file is moved to the final location after the command completes.

set -uo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
log_file="$repo_root/target/runner.log"
error_pattern='^\[ERROR\]'
label=""
max_lines=20

while [[ $# -gt 0 ]]; do
  case "$1" in
    --error-pattern) error_pattern="$2"; shift 2 ;;
    --label)         label="$2";         shift 2 ;;
    --)              shift; break ;;
    *)               break ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "Usage: run-cmd [--error-pattern PATTERN] [--label LABEL] -- COMMAND [ARGS...]" >&2
  exit 1
fi

[[ -z "$label" ]] && label="$(basename "$1")"

tmp_log=$(mktemp "${TMPDIR:-/tmp}/runner.XXXXXX.log")
trap 'rm -f "$tmp_log"' EXIT

start_time=$(date +%s)
exit_code=0
"$@" > "$tmp_log" 2>&1 || exit_code=$?
end_time=$(date +%s)
elapsed=$((end_time - start_time))

# Move temp log to final location (recreate target/ if clean nuked it)
mkdir -p "$(dirname "$log_file")"
mv "$tmp_log" "$log_file"

if [[ $exit_code -eq 0 ]]; then
  echo "$label succeeded (${elapsed}s)"
  exit 0
fi

echo "$label failed (exit $exit_code, ${elapsed}s)" >&2
error_lines=$(grep -E "$error_pattern" "$log_file" | head -n "$max_lines" || true)
if [[ -n "$error_lines" ]]; then
  echo "$error_lines" >&2
else
  tail -n "$max_lines" "$log_file" >&2
fi
echo "Full log: $log_file" >&2
exit "$exit_code"
