#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(dirname "$0")"

echo "Starting backend..."
"$SCRIPT_DIR/run-app" &
BACKEND_PID=$!

echo ""
echo "Backend: http://localhost:8080"
echo "Press Ctrl+C to stop"
trap "kill $BACKEND_PID 2>/dev/null; docker compose down 2>/dev/null || true; docker rm -f template-postgres 2>/dev/null || true; exit" INT TERM
wait "$BACKEND_PID"
